# DeepSeek API key — used by scripts/generate_content.py
# Get yours at https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Formspree form ID — used by the contact form and newsletter signup
# Create a free form at https://formspree.io (50 submissions/month free)
# The form ID is the last part of your Formspree endpoint URL
NEXT_PUBLIC_FORMSPREE_FORM_ID=your_formspree_form_id_here
